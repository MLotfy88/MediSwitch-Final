{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "TypeScript: Watch Errors",
            "type": "shell",
            "command": "npx tsc --watch --noEmit",
            "isBackground": true,
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$tsc-watch",
            "options": {
                "cwd": "${workspaceFolder}/admin-dashboard"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "clear": true
            },
            "runOptions": {
                "runOn": "folderOpen"
            }
        },
        {
            "label": "Admin Dashboard: Check Build",
            "type": "shell",
            "command": "npm run build:dev",
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}/admin-dashboard"
            },
            "problemMatcher": [
                "$tsc",
                {
                    "owner": "vite",
                    "fileLocation": [
                        "relative",
                        "${workspaceFolder}/admin-dashboard"
                    ],
                    "pattern": {
                        "regexp": "^(.*):(\\d+):(\\d+):\\s+(error|warning):\\s+(.*)$",
                        "file": 1,
                        "line": 2,
                        "column": 3,
                        "severity": 4,
                        "message": 5
                    }
                }
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "ESLint: Check All Files",
            "type": "shell",
            "command": "npm run lint",
            "options": {
                "cwd": "${workspaceFolder}/admin-dashboard"
            },
            "problemMatcher": "$eslint-stylish",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "TypeScript: Check All Files",
            "type": "shell",
            "command": "npx tsc --noEmit",
            "options": {
                "cwd": "${workspaceFolder}/admin-dashboard"
            },
            "problemMatcher": "$tsc",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Flutter: Analyze All",
            "type": "shell",
            "command": "flutter analyze",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": {
                "owner": "dart",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}"
                ],
                "pattern": [
                    {
                        "regexp": "^\\s+(info|warning|error)\\s+.+\\s+(.+):(\\d+):(\\d+)\\s+",
                        "severity": 1,
                        "file": 2,
                        "line": 3,
                        "column": 4
                    }
                ]
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}